# ============================================================
# FLYTRACK - Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================================

# --- Base de Datos PostgreSQL ---
POSTGRES_DB=flytrackdb
POSTGRES_USER=flytrack
POSTGRES_PASSWORD=change_me_in_production

# --- Backend Spring Boot ---
DB_URL=jdbc:postgresql://flytrack-db:5432/flytrackdb
DB_USER=flytrack
DB_PASS=change_me_in_production
SERVER_PORT=8080

# --- Frontend ---
FRONTEND_PORT=80
